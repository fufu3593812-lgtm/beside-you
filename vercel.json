{
  "rewrites": [
    {"source": "/api/mcp", "destination": "/api/mcp.js"},
    {"source": "/api/zombie/:path*", "destination": "/api/zombie.js"},
    {"source": "/api/letter-test", "destination": "/api/letter-test.js"},
    {"source": "/api/:path*", "destination": "/api/index.js"}
  ],
  "headers": [
    {
      "source": "/src/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
