{
  "rewrites": [
    {"source": "/api/mcp", "destination": "/api/mcp.js"},
    {"source": "/api/user/sync-intimacy", "destination": "/api/user/sync-intimacy.js"},
    {"source": "/api/user/touch", "destination": "/api/user/sync-intimacy.js"},
    {"source": "/api/zombie/:path*", "destination": "/api/zombie.js"},
    {"source": "/api/fix/:path*", "destination": "/api/fix.js"},
    {"source": "/api/:path*", "destination": "/api/index.js"}
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"},
        {"key": "Pragma", "value": "no-cache"}
      ]
    }
  ]
}
